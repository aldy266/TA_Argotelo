DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=


# ==========================
# FLASK CONFIG
# ==========================

SECRET_KEY=
POS_TAX_RATE=0
MAX_UPLOAD_SIZE=5242880


# ==========================
# CLOUDINARY CONFIG
# ==========================

CLOUDINARY_CLOUD_NAME=
