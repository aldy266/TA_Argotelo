# ==========================
# RESEND EMAIL CONFIG
# ==========================

# Use a verified Resend domain/address for production. The Resend onboarding
# sender can only deliver to the email address associated with the Resend account.
RESEND_API_KEY=
RESEND_FROM=Argotelo <onboarding@resend.dev>
# Public/LAN address reachable from the device that opens the email.
APP_BASE_URL=http://127.0.0.1:5000
